[*]
charset = utf-8
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{csproj,slnx}]
indent_size = 2

[*.cs]
file_header_template = Copyright (c) KappaDuck. All rights reserved.\nThe source code is licensed under MIT License.
dotnet_sort_system_directives_first = false
dotnet_analyzer_diagnostic.severity = warning

[*.{config,nuspec,props,targets,xml}]
indent_size = 2

[*.json]
indent_size = 2

[*.{yaml,yml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.{html,svg}]
indent_size = 2

[*.css]
indent_size = 2

[*.{js,ts}]
indent_size = 2
